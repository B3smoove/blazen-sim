# =============================================================================
# Blazen Sim – Backend Environment Variables
# Copy this file to .env and fill in all values before running the server.
# NEVER commit .env to version control.
# =============================================================================

# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000
ALLOWED_ORIGIN=http://localhost:5173

# ── Anthropic Claude API ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── DEVS-FIRE API ───────────────────────────────────────────────────────────
DEVS_FIRE_BASE_URL=https://firesim.cs.gsu.edu
DEVS_FIRE_EMAIL=your_registered_email@example.com
DEVS_FIRE_PASSWORD=your_password
DEVS_FIRE_TIMEOUT_MS=90000

# ── Rate Limiter (in-memory) ─────────────────────────────────────────────────
RATE_LIMIT_MAX_CALLS=100
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_BASE_BACKOFF_S=5
RATE_LIMIT_MAX_BACKOFF_S=300
